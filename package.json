{
  "name": "prompt-vault",
  "private": true,
  "version": "0.1.0",
  "author": "prompt-vault team",
  "description": "Local AI prompt manager",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "node scripts/generate-icon.mjs && pnpm build && electron-builder --win --dir && node scripts/patch-exe-icon.mjs && electron-builder --prepackaged release/win-unpacked --win nsis",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "element-plus": "^2.9.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "png-to-ico": "^3.0.2",
    "rcedit": "^5.0.2",
    "typescript": "~5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.prompt-vault.app",
    "productName": "提示词库",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "icon": "build/icon.ico",
    "win": {
      "icon": "build/icon.ico",
      "executableName": "prompt-vault",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "提示词库",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "include": "build/installer.nsh"
    }
  }
}
